# Local Worker secrets — copy to web/.dev.vars (git-ignored) and fill in.
# In production, set via: npx wrangler secret put ANTHROPIC_API_KEY
# The key must NEVER appear in browser code, NEXT_PUBLIC_* vars, or git.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# EXPLAIN_PROVIDER=fake      # force the mock provider even with a key
# EXPLAIN_MODEL=claude-haiku-4-5

# Turnstile: local dev pairs Cloudflare's always-pass TEST secret with the
# TEST sitekey the frontend uses on localhost. Production uses the real
# secret (wrangler secret put TURNSTILE_SECRET_KEY). Omit to disable
# verification locally.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
