/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: SAMEORIGIN

# COOP/COEP only on DOCUMENTS that need crossOriginIsolated (threaded engine).
# /turnstile.html must stay OUT of this list: it hosts the Turnstile widget
# inside a credentialless iframe, and Turnstile's own challenge iframe cannot
# load under a COEP document (verified empirically — net::ERR_ABORTED).
#
# CSP (defense-in-depth; React escapes by default, this is the backstop):
# - 'unsafe-inline' scripts: required — Next static export emits inline
#   bootstrap scripts without nonces.
# - 'wasm-unsafe-eval' + worker-src blob:: the Stockfish WASM engine.
# - `next dev` does NOT get this header (HMR needs eval) — verify CSP
#   changes with `pnpm preview`, not the dev server.
/
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self'; frame-src 'self'; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'self'
/index.html
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self'; frame-src 'self'; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'self'
# The Turnstile host page needs the challenge script + iframe from
# challenges.cloudflare.com and nothing else.
/turnstile.html
  Content-Security-Policy: default-src 'self'; script-src 'unsafe-inline' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; style-src 'unsafe-inline'; connect-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'self'
# Dedicated worker scripts must carry COEP compatible with their creator
# document, or worker creation is blocked (ERR_BLOCKED_BY_RESPONSE).
/engine/*
  Cross-Origin-Embedder-Policy: require-corp
