{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chess-web",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-14",
  // The Anthropic SDK imports node:fs/node:path (credential-chain code that
  // is unused at runtime here, but must resolve at startup).
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    // Only /api/* invokes the Worker; everything else is served as a static
    // asset directly (cheaper, and _headers applies COOP/COEP to the document).
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  },
  // Per-IP rate limit for /api/explain (the endpoint that spends LLM tokens).
  // Free on all plans; counters are per-colo and eventually consistent — this
  // is an abuse brake, not an accounting system. Turnstile comes before any
  // public marketing push (see ROADMAP Phase 2).
  "ratelimits": [
    {
      "name": "EXPLAIN_RATELIMIT",
      "namespace_id": "1001",
      "simple": { "limit": 10, "period": 60 }
    }
  ],
  // Global daily budget: one strongly-consistent counter capping the WHOLE
  // worker's explanations/day (the per-IP limit has no aggregate ceiling).
  // SQLite-backed class = available on the free plan.
  "durable_objects": {
    "bindings": [{ "name": "BUDGET", "class_name": "BudgetCounter" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["BudgetCounter"] }],
  "vars": {
    // ~$1.50/day worst case at Haiku prices with the 512-token output cap.
    "DAILY_BUDGET": "300"
  }
}
