{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Bash(uv sync:*)",
      "Bash(pnpm install)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm --filter web:*)",
      "Bash(pnpm dlx shadcn@latest add:*)",
      "Bash(npx wrangler dev:*)",
      "WebFetch(domain:lichess.org)",
      "WebFetch(domain:developers.cloudflare.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_edit.py",
            "timeout": 90
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/stop_check.py",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
